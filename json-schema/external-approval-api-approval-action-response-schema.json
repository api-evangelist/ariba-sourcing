{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ariba-sourcing/refs/heads/main/json-schema/external-approval-api-approval-action-response-schema.json",
  "title": "ApprovalActionResponse",
  "description": "Response from submitting an approval action.",
  "type": "object",
  "properties": {
    "taskId": {
      "type": "string",
      "description": "Task identifier.",
      "example": "TASK-500123"
    },
    "action": {
      "type": "string",
      "description": "Action submitted.",
      "example": "approve"
    },
    "status": {
      "type": "string",
      "description": "Result status.",
      "example": "submitted"
    }
  }
}